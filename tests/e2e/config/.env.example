# WooPayments E2E Local Environment Configuration
#
# Copy this file to local.env and fill in your values:
#   cp tests/e2e/config/.env.example tests/e2e/config/local.env
#
# Or generate automatically:
#   bin/setup-e2e-local.sh
#
# See tests/e2e/README.md for full documentation.

# ─── Dev Tools ────────────────────────────────────────────────────────────────
# Path or URL to poocommerce-payments-dev-tools repo.
# Prefer a local checkout when available. Remote GitHub URLs require working
# SSH or HTTPS auth.
# Tip: if running the dev Docker environment, this is usually at:
#   docker/wordpress/wp-content/plugins/poocommerce-payments-dev-tools
WCP_DEV_TOOLS_REPO=''

# ─── Transact Platform Server (local mode) ───────────────────────────────────
# Path or git URL to transact-platform-server repo.
# Prefer a local checkout when you need uncommitted server changes mirrored into
# E2E. If the sandbox-backed server/ and missioncontrol/ directories are
# missing, setup will try `npm run pull -- -s` in the E2E clone, which requires
# sandbox SSH access and rsync.
# Required for local server mode (the default).
TRANSACT_PLATFORM_SERVER_REPO=''

# ─── Stripe Credentials ──────────────────────────────────────────────────────
# Found in transact-platform-server/local/secrets.php or the Stripe Dashboard.
E2E_WCPAY_STRIPE_TEST_PUBLIC_KEY='pk_test_xxx'
E2E_WCPAY_STRIPE_TEST_SECRET_KEY='sk_test_xxx'
E2E_WCPAY_STRIPE_TEST_WEBHOOK_SIGNATURE_KEY='whsec_xxx'

# Connected Stripe account ID (acct_xxx).
# Can be auto-created by bin/setup-e2e-local.sh.
E2E_WCPAY_STRIPE_ACCOUNT_ID='acct_xxx'

# WPCOM Site ID for WooPay. Default: 111 (test value).
E2E_WOOPAY_BLOG_ID='111'

# ─── Live Server Mode (alternative to local) ─────────────────────────────────
# Uncomment to use the live WPCOM API instead of a local Transact server.
# E2E_USE_LOCAL_SERVER=false
# E2E_JP_BLOG_TOKEN=''
# E2E_JP_USER_TOKEN=''
# E2E_JP_SITE_ID=''

# ─── Test Scope ──────────────────────────────────────────────────────────────
# Remove the value (leave empty) to include each test group.
SKIP_WC_SUBSCRIPTIONS_TESTS=1
SKIP_WC_ACTION_SCHEDULER_TESTS=1
SKIP_WC_BLOCKS_TESTS=1

# GitHub token — required only for WC Subscriptions tests.
# E2E_GH_TOKEN=''
# WC_SUBSCRIPTIONS_REPO=''

# ─── Version Overrides ───────────────────────────────────────────────────────
# Uncomment to test specific versions (defaults to latest).
# E2E_WP_VERSION='6.7.0'
# E2E_WC_VERSION='9.5.0'

# ─── Debug ────────────────────────────────────────────────────────────────────
# Set to true for verbose Docker output during setup.
DEBUG=false
